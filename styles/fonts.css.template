/* @font-face rules — version injected at build via scripts/font-asset-version.mjs */
@font-face {
  font-family: "Vazirmatn";
  src: url("/fonts/Vazirmatn/Vazirmatn-Arabic-400.woff2?v=__FONT_VERSION__") format("woff2");
  font-style: normal;
  font-weight: 400;
  font-display: swap;
}

